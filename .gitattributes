# Enforce LF line endings in the repo regardless of OS.
# Prevents ruff format --check from failing on Linux CI after editing on Windows.
* text=auto eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.env* text eol=lf
Dockerfile text eol=lf
